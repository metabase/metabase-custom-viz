{
  "name": "@metabase/custom-viz",
  "version": "0.0.1",
  "description": "CLI for creating and bundling custom visualizations for Metabase",
  "type": "module",
  "bin": {
    "metabase-custom-viz": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "lint": "oxlint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "npm run build && np"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "np": "^10.2.0",
    "oxlint": "^0.16.6",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.2"
  }
}
